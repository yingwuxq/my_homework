// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug Huffman",
    "program": "${ZED_WORKTREE_ROOT}/huffman.exe",
    "request": "launch",
    "adapter": "GDB",       // Windows下也可尝试 "GDB"
    "args": [],                  // 无需额外参数
    "cwd": "$ZED_WORKTREE_ROOT",
    "build": {
      "command": "gcc",
      "args": ["-g", "huffman.c", "-o", "huffman.exe"],
      "cwd": "${ZED_WORKTREE_ROOT}"
    }
  }
]
